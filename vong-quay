<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vòng quay may mắn Spa</title>

<style>
body {
    text-align: center;
    font-family: Arial, sans-serif;
    background: #8C6344;
    margin: 0;
    padding: 0;
}

h1 {
    color: white;
    margin-top: 20px;
}

.container {
    display: flex;
    flex-direction: column;
    align-items: center;
}

/* canvas responsive */
canvas {
    width: 90vw;
    max-width: 600px;
    height: auto;
}

/* nút quay */
button {
    margin-top: 20px;
    padding: 15px 30px;
    font-size: 20px;
    background: #ff4081;
    color: white;
    border: none;
    border-radius: 10px;
    cursor: pointer;
}

/* mũi tên */
.pointer {
    width: 0;
    height: 0;
    border-left: 15px solid transparent;
    border-right: 15px solid transparent;
    border-bottom: 30px solid yellow;
    margin-bottom: -10px;
}
</style>
</head>

<body>

<h1>🎁 Vòng quay may mắn</h1>

<div class="container">
    <div class="pointer"></div>
    <canvas id="wheel" width="1000" height="1000"></canvas>
    <button onclick="spin()">QUAY NGAY</button>
</div>

<script>
const canvas = document.getElementById("wheel");
const ctx = canvas.getContext("2d");

const prizes = [
"Voucher 100k","Voucher 100k","Voucher 100k",
"Voucher 200k",
"Gội đầu 160k",
"Nước uống 50k","Nước uống 50k","Nước uống 50k","Nước uống 50k",
"Chúc may mắn"
];

const colors = [
"#FFCDD2","#F8BBD0","#E1BEE7","#D1C4E9","#C5CAE9",
"#BBDEFB","#B2EBF2","#C8E6C9","#DCEDC8","#FFF9C4"
];

let startAngle = 0;
let spinning = false;

function drawWheel() {
    let arc = Math.PI * 2 / prizes.length;

    for (let i = 0; i < prizes.length; i++) {
        let angle = startAngle + i * arc;

        ctx.beginPath();
        ctx.fillStyle = colors[i];
        ctx.moveTo(500, 500);
        ctx.arc(500, 500, 480, angle, angle + arc);
        ctx.fill();

        ctx.save();
        ctx.fillStyle = "#000";
        ctx.translate(500, 500);
        ctx.rotate(angle + arc / 2);
        ctx.textAlign = "right";
        ctx.font = "20px Arial";
        ctx.fillText(prizes[i], 450, 10);
        ctx.restore();
    }
}

function easeOut(t) {
    return 1 - Math.pow(1 - t, 3);
}

function spin() {
    if (spinning) return;
    spinning = true;

    let spinAngle = Math.random() * 2000 + 3000;
    let duration = 4000;
    let start = null;

    function animate(time) {
        if (!start) start = time;
        let progress = time - start;
        let t = progress / duration;

        let eased = easeOut(t);
        let angle = spinAngle * (1 - eased);

        startAngle += angle * Math.PI / 180;

        ctx.clearRect(0, 0, 1000, 1000);
        drawWheel();

        if (progress < duration) {
            requestAnimationFrame(animate);
        } else {
            spinning = false;
            showResult();
        }
    }

    requestAnimationFrame(animate);
}

function showResult() {
    let arc = Math.PI * 2 / prizes.length;
    let index = Math.floor((2 * Math.PI - (startAngle % (2 * Math.PI))) / arc) % prizes.length;
    alert("🎉 Bạn trúng: " + prizes[index]);
}

drawWheel();
</script>

</body>
</html>
